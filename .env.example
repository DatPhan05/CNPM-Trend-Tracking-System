# ============================================
# CNPM Trend Tracking System - Environment Config
# ============================================
# Copy this file to .env and update values as needed.
#
# There are TWO modes:
#   1. LOCAL development  (run with npm run dev)
#   2. DOCKER deployment  (run with docker compose up)
# ============================================

# ---- Frontend ----
VITE_APP_NAME=Scientific Journal Publication Trend Tracking System
VITE_ENV=development

# ---- Backend ----
PORT=8080
JWT_SECRET=your_jwt_access_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
FRONTEND_URL=http://localhost:5173

# ============================================
# Choose ONE of the following DATABASE_URL configs:
# ============================================

# LOCAL development (connect to Docker postgres on exposed port 5434)
# VITE_API_BASE_URL=http://localhost:8080/api
# DATABASE_URL=postgresql://admin:admin123@localhost:5434/scientific_trend_db

# DOCKER COMPOSE (used inside containers, postgres resolves via Docker DNS)
VITE_API_BASE_URL=http://localhost/api
DATABASE_URL=postgresql://admin:admin123@postgres:5432/scientific_trend_db