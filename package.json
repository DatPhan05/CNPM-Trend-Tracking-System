{
  "name": "scientific-journal-publication-trend-tracking-system",
  "version": "1.0.0",
  "description": "Scientific Journal Publication Trend Tracking System",
  "scripts": {
    "dev": "tsx watch backend/src/server.ts",
    "start": "tsc && node backend/dist/src/server.js",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:seed": "npx tsx database/seeds/seed_data.ts",
    "scrape": "tsx backend/src/services/scraper.ts",
    "test": "jest --runInBand",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:start": "npm run start --prefix frontend",
    "test:e2e": "npm run test:e2e --prefix frontend"
  },
  "keywords": [
    "scientific-journal",
    "publication-trends",
    "software-engineering-project"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/design.md": "^0.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.107.0",
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.19.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.5.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.15",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "prisma": {
    "seed": "npx tsx database/seeds/seed_data.ts",
    "schema": "backend/prisma/schema.prisma"
  },
  "workspaces": [
    "frontend"
  ]
}
